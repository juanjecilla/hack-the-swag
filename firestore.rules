rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Public community bingo board: anyone can read, but only signed-in
    // (Google) users can add a fun fact, and the entry must be stamped with
    // their own uid. Existing entries cannot be edited or deleted.
    match /entries/{id} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.submittedByUid == request.auth.uid
                    && request.resource.data.keys().hasOnly([
                         'fact', 'person', 'gdgCommunity', 'submittedBy',
                         'submittedByUid', 'submittedByEmail', 'exactMatch', 'createdAt'])
                    && request.resource.data.fact is string
                    && request.resource.data.fact.size() > 0
                    && request.resource.data.fact.size() <= 140
                    && request.resource.data.person is string
                    && request.resource.data.person.size() > 0
                    && request.resource.data.person.size() <= 60
                    && request.resource.data.gdgCommunity is string
                    && request.resource.data.gdgCommunity.size() > 0
                    && request.resource.data.gdgCommunity.size() <= 80
                    && request.resource.data.exactMatch is bool
                    && request.resource.data.createdAt == request.time;
      allow update, delete: if false;
    }

    // Community flags ("duplicate" / "wrong"). Doc id is
    // `${entryId}__${uid}__${type}`, so each user can flag an entry once per
    // type and toggle it off. Anyone can read the aggregate; only the owner
    // can create or remove their own flag, and they cannot edit it in place.
    match /flags/{id} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid
                    && id == request.resource.data.entryId + '__' + request.auth.uid + '__' + request.resource.data.type
                    && request.resource.data.type in ['duplicate', 'wrong'];
      allow delete: if request.auth != null
                    && resource.data.uid == request.auth.uid;
      allow update: if false;
    }
  }
}
